{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ableton Library",
  "version": "0.1.0",
  "identifier": "com.carlitos.ableton-library",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ableton Library",
        "width": 1150,
        "height": 780,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
